# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pm_yc?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pm-yc"
S3_REGION="us-east-1"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Magic link email (SMTP connection string)
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@pm-yc.com"

# SAML SSO (optional — requires BoxyHQ SAML Jackson instance)
# JACKSON_URL="http://localhost:5225"

# AI Providers
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Integrations — Intercom
INTERCOM_CLIENT_ID=""
INTERCOM_CLIENT_SECRET=""
INTERCOM_WEBHOOK_SECRET=""

# Integrations — Zendesk
ZENDESK_CLIENT_ID=""
ZENDESK_CLIENT_SECRET=""
ZENDESK_WEBHOOK_SECRET=""

# Integrations — Salesforce
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""

# Integrations — HubSpot
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# App
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_BASE_URL="http://localhost:4000"
API_PORT=4000
MCP_PORT=4001
NODE_ENV="development"
